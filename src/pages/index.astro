---
import BaseLayout from "../layouts/BaseLayout.astro";
import { parseCaseStudy, resolveCaseStudyPath } from "../lib/parse-case-study";
import HomeHero from "../components/HomeHero.astro";
import WaveDivider from "../components/case-study/WaveDivider.astro";
import ProjectRow from "../components/ProjectRow.astro";
import AboutParallax from "../components/AboutParallax.astro";
import MarkdownContent from "../components/case-study/MarkdownContent.astro";

const { frontmatter, blocks } = parseCaseStudy(resolveCaseStudyPath("home.md"));
const fixPath = (p: string) => (p && !p.startsWith("/") ? `/${p}` : p);

const projectRows = blocks.filter((b) => b.kind === "project-row") as Extract<
  (typeof blocks)[number],
  { kind: "project-row" }
>[];

const aboutParallax = blocks.find((b) => b.kind === "about-parallax") as
  | Extract<(typeof blocks)[number], { kind: "about-parallax" }>
  | undefined;
---

<BaseLayout title="Liam Oxley — Portfolio">
  
  <HomeHero
    title={frontmatter.title}
    description={frontmatter.description}
    heroImage={frontmatter.heroImage}
  />

  <div class="bg-[linear-gradient(to_bottom,#F9DABF,#FFC297)] -mt-1 w-full relative z-20 pointer-events-none">
    <WaveDivider fill="#ffffff" position="bottom" class="w-full" />
  </div>

  <div class="bg-white pb-24 pt-12 text-neutral-900 relative z-10">
    <div class="max-w-[1200px] mx-auto px-6 mb-16">
      <h2 class="font-serif text-4xl font-medium text-neutral-900">Featured Work</h2>
    </div>
    
    <div class="flex flex-col gap-20 max-w-[1200px] mx-auto">
      {projectRows.map((block) => (
        <div class="border-b border-neutral-100 pb-20 last:border-b-0">
          <ProjectRow
            theme={block.attrs.theme as string}
            link={block.attrs.link as string}
            image={block.attrs.image as string}
            imagePos={block.attrs.imagePos as "left" | "right"}
            content={block.content || ""}
          />
        </div>
      ))}
    </div>
  </div>

  <div class="bg-white -mb-1 w-full relative z-20 pointer-events-none">
    <WaveDivider position="top" fill="#F3F0FA" class="w-full" />
  </div>

  <div class="bg-[#F3F0FA] pt-12 pb-24 relative z-10">
    <div class="max-w-[1200px] mx-auto px-6">
      <h2 class="font-serif text-4xl font-medium text-neutral-900 mb-12">About Me</h2>
      
      {aboutParallax ? (
        <div class="flex flex-col md:flex-row gap-12 md:gap-16 items-start">
          <div class="md:w-[55%] text-lg leading-relaxed text-neutral-700">
            <MarkdownContent content={aboutParallax.content || ""} reveal={false} />
          </div>
          <div class="md:w-[45%] flex justify-center max-w-[420px] mx-auto">
            <AboutParallax
              far={fixPath(aboutParallax.attrs.far as string)}
              mid={fixPath(aboutParallax.attrs.mid as string)}
              front={fixPath(aboutParallax.attrs.front as string)}
            />
          </div>
        </div>
      ) : (
        /* 🛡️ BULLETPROOF FALLBACK: If your home.md text gets accidentally wiped or broken again, 
           this manual layout ensures your biography and portraits never vanish from the screen. */
        <div class="flex flex-col md:flex-row gap-12 md:gap-16 items-start">
          <div class="md:w-[55%] text-lg leading-relaxed text-neutral-700 space-y-6">
            <p>
              I turn fragile, manual workflows into robust automated systems. I use my background in operations and experience design to fix broken workflows and build digital tools that are as reliable as they are easy to use.
            </p>
            <a href="/about" class="inline-block text-purple-600 font-medium hover:underline">
              Discover My Journey 〰️>
            </a>
          </div>
          <div class="md:w-[45%] flex justify-center max-w-[420px] mx-auto">
             <img src="/assets/home/home-hero-portrait.webp" class="w-full h-auto rounded-2xl border border-neutral-200/50" alt="Liam Portrait" />
          </div>
        </div>
      )}
    </div>
  </div>
</BaseLayout>