---
import BaseLayout from "../layouts/BaseLayout.astro";
import { parseCaseStudy, resolveCaseStudyPath } from "../lib/parse-case-study";
import HomeHero from "../components/HomeHero.astro";
import WaveDivider from "../components/case-study/WaveDivider.astro";
import ProjectRow from "../components/ProjectRow.astro";
import AboutParallax from "../components/AboutParallax.astro";
import MarkdownContent from "../components/case-study/MarkdownContent.astro";

const { frontmatter, blocks } = parseCaseStudy(resolveCaseStudyPath("home.md"));

const fixPath = (p: string) => (p && !p.startsWith("/") ? `/${p}` : p);

const projectRows = blocks.filter((b) => b.kind === "project-row") as Extract<
  (typeof blocks)[number],
  { kind: "project-row" }
>[];

const aboutParallax = blocks.find((b) => b.kind === "about-parallax") as
  | Extract<(typeof blocks)[number], { kind: "about-parallax" }>
  | undefined;
---

<BaseLayout title="Liam Oxley — Portfolio">
  
  <div class="sticky top-0 z-0 w-full bg-[linear-gradient(to_bottom,#F9DABF,#FFC297)] overflow-hidden">
    <HomeHero
      title={frontmatter.title as string}
      description={frontmatter.description as string}
      heroImage={fixPath(frontmatter.heroImage as string)} 
      imageAlt={frontmatter.imageAlt as string || "Liam collaborating at a design table"} 
    />
  </div>

  <div class="relative z-10 w-full">
    
    <div 
      id="tall-projects-card" 
      class="sticky z-10 w-full bg-white pb-16 pt-16 text-neutral-900"
    >
      <div class="absolute bottom-full left-0 w-full z-20 leading-[0] pointer-events-none translate-y-[2px]">
        <WaveDivider fill="#ffffff" position="bottom" class="w-full block" />
      </div>

      <div class="max-w-[1200px] mx-auto px-6 mb-4">
        <h2 class="font-serif text-4xl font-medium text-neutral-900">Featured Work</h2>
      </div>

      <div class="flex flex-col divide-y divide-neutral-200 max-w-[1200px] mx-auto px-6">
        {projectRows.map((block) => (
          <div class="py-8 first:pt-0 last:pb-0">
            <ProjectRow
              theme={block.attrs.theme as string}
              link={block.attrs.link as string}
              image={block.attrs.image as string}
              imagePos={block.attrs.imagePos as "left" | "right"}
              content={block.content || ""}
            />
          </div>
        ))}
      </div>
    </div> 

    <div class="relative z-20 w-full bg-[#F3F0FA] pt-24 pb-36 min-h-screen">
      
      <div class="absolute bottom-full left-0 w-full z-20 leading-[0] pointer-events-none translate-y-[2px]">
        <WaveDivider fill="#F3F0FA" position="bottom" class="w-full block" />
      </div>

      <div class="max-w-[1200px] mx-auto px-6 w-full">
        <h2 class="font-serif text-4xl font-medium text-neutral-900 mb-12">About Me</h2>
        {aboutParallax && (
          <div class="flex flex-col md:flex-row gap-12 md:gap-16 items-start">
            <div class="md:w-[55%] text-lg leading-relaxed text-neutral-700">
              <MarkdownContent content={aboutParallax.content || ""} reveal={false} />
            </div>
            <div class="md:w-[45%] relative flex justify-center items-center w-full">
              {aboutParallax.attrs.front || aboutParallax.attrs.far ? (
                <AboutParallax
                  far={aboutParallax.attrs.far ? fixPath(aboutParallax.attrs.far as string) : undefined}
                  front={aboutParallax.attrs.front ? fixPath(aboutParallax.attrs.front as string) : undefined}
                >
                  <img src="/assets/home/home-hero-portrait.webp" class="relative z-10 w-full max-w-[300px] sm:max-w-[340px] md:max-w-[380px] h-auto object-contain" alt="Liam Portrait" />
                </AboutParallax>
              ) : (
                <img src="/assets/home/home-hero-portrait.webp" class="w-full max-w-[380px] h-auto rounded-2xl border border-neutral-200/60 shadow-sm object-contain bg-white p-2" alt="Liam Portrait" />
              )}
            </div>
          </div>
        )}
      </div>
    </div> 

  </div> 
</BaseLayout>

<script>
  // 💡 JANK-FREE FIX: Uses true window.innerHeight for butter-smooth mobile/desktop locking
  const projectsCard = document.getElementById("tall-projects-card");
  
  if (projectsCard) {
    const updateSticky = () => {
      const vh = window.innerHeight;
      const h = projectsCard.offsetHeight;
      projectsCard.style.top = `${vh - h}px`;
    };

    // Calculate immediately, and dynamically monitor for layout changes
    updateSticky();
    new ResizeObserver(updateSticky).observe(projectsCard);
    window.addEventListener('resize', updateSticky, { passive: true });
  }
</script>