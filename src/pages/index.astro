---
import BaseLayout from "../layouts/BaseLayout.astro";
import { parseCaseStudy, resolveCaseStudyPath } from "../lib/parse-case-study";
import HomeHero from "../components/HomeHero.astro";
import WaveDivider from "../components/case-study/WaveDivider.astro";
import ProjectRow from "../components/ProjectRow.astro";
import AboutParallax from "../components/AboutParallax.astro";
import MarkdownContent from "../components/case-study/MarkdownContent.astro";

const { frontmatter, blocks } = parseCaseStudy(resolveCaseStudyPath("home.md"));

const fixPath = (p: string) => (p && !p.startsWith("/") ? `/${p}` : p);

const projectRows = blocks.filter((b) => b.kind === "project-row") as Extract<
  (typeof blocks)[number],
  { kind: "project-row" }
>[];

const aboutParallax = blocks.find((b) => b.kind === "about-parallax") as
  | Extract<(typeof blocks)[number], { kind: "about-parallax" }>
  | undefined;
---

<BaseLayout title="Liam Oxley — Portfolio">
  
  <div id="hero-layer" class="sticky top-0 z-0 w-full min-h-screen bg-[linear-gradient(to_bottom,#F9DABF,#FFC297)] overflow-hidden will-change-transform">
    <HomeHero
      title={frontmatter.title as string}
      description={frontmatter.description as string}
      heroImage={fixPath(frontmatter.heroImage as string)} 
      imageAlt={frontmatter.imageAlt as string || "Liam collaborating at a design table"} 
    />
  </div>

  <div class="relative z-10 w-full">
    
    <div 
      id="projects-layer" 
      class="sticky z-10 w-full bg-white pb-16 pt-16 text-neutral-900 will-change-transform"
    >
      <div class="absolute bottom-full left-0 w-full z-20 leading-[0] pointer-events-none translate-y-[2px]">
        <WaveDivider fill="#ffffff" position="bottom" class="w-full block" />
      </div>

      <div class="max-w-[1200px] mx-auto px-6 mb-8 w-full">
        <h2 class="font-serif text-[clamp(1.75rem,2vw,2.5rem)] font-normal text-neutral-400 pb-4 border-b border-[#D8D8D8]">
          Featured Work
        </h2>
      </div>

      <div class="flex flex-col divide-y divide-neutral-200 max-w-[1200px] mx-auto px-6">
        {projectRows.map((block) => (
          <div class="py-8 first:pt-0 last:pb-0">
            <ProjectRow
              theme={block.attrs.theme as string}
              link={block.attrs.link as string}
              image={block.attrs.image as string}
              imagePos={block.attrs.imagePos as "left" | "right"}
              content={block.content || ""}
            />
          </div>
        ))}
      </div>
    </div> 

    <div id="about-layer" class="sticky z-20 w-full">
      
      <div id="about-inner" class="w-full bg-[#F3F0FA] pt-24 pb-36 min-h-screen relative will-change-transform">
        
        <div class="absolute bottom-full left-0 w-full z-20 leading-[0] pointer-events-none translate-y-[2px]">
          <WaveDivider fill="#F3F0FA" position="bottom" class="w-full block" />
        </div>

        <div class="max-w-[1200px] mx-auto px-6 w-full">
          {aboutParallax && (
            <div class="flex flex-col md:flex-row gap-12 md:gap-16 items-center">
              
              <div class="w-full md:w-[55%] flex flex-col items-start">
                
                <div class="w-full mb-5">
                  <h2 class="font-serif text-[clamp(1.75rem,4vw,2.5rem)] font-normal text-neutral-500 pb-2 border-b border-[#D8D8D8]">
                    About Me
                  </h2>
                </div>
                
                <div class="text-xl md:text-[1.25rem] leading-relaxed text-neutral-700">
                  <MarkdownContent content={aboutParallax.content || ""} reveal={false} />
                </div>
                
                <a 
                  href="/about" 
                  class="inline-flex items-center justify-center mt-8 px-6 py-3 border-2 border-[#4B32A8] text-[#4B32A8] font-sans font-semibold text-sm tracking-wide rounded-full bg-transparent hover:bg-[#4B32A8] hover:text-white transition-all duration-300 ease-out transform hover:scale-[1.03] shadow-sm hover:shadow-md"
                >
                  More About Me
                </a>
              </div>
              
              <div class="md:w-[45%] relative flex justify-center items-center w-full">
                {aboutParallax.attrs.front || aboutParallax.attrs.far ? (
                  <AboutParallax
                    far={aboutParallax.attrs.far ? fixPath(aboutParallax.attrs.far as string) : undefined}
                    front={aboutParallax.attrs.front ? fixPath(aboutParallax.attrs.front as string) : undefined}
                  >
                    <img src="/assets/home/home-hero-portrait.webp" class="relative z-10 w-full max-w-[300px] sm:max-w-[340px] md:max-w-[380px] h-auto object-contain" alt="Liam Portrait" />
                  </AboutParallax>
                ) : (
                  <img src="/assets/home/home-hero-portrait.webp" class="w-full max-w-[380px] h-auto rounded-2xl border border-neutral-200/60 shadow-sm object-contain bg-white p-2" alt="Liam Portrait" />
                )}
              </div>
              
            </div>
          )}
        </div>

        <div class="absolute top-full left-0 w-full h-[50vh] bg-[#F3F0FA] pointer-events-none"></div>
        
      </div>
    </div> 

  </div> 
</BaseLayout>

<script>
  // ==========================================
  // 1. DYNAMIC STICKY HEIGHT LOCK
  // ==========================================
  const projectsCard = document.getElementById("projects-layer");
  const aboutCard = document.getElementById("about-layer");
  
  const updateSticky = () => {
    const vh = window.innerHeight;
    if (projectsCard) {
      projectsCard.style.top = `${vh - projectsCard.offsetHeight}px`;
    }
    if (aboutCard) {
      aboutCard.style.top = `${vh - aboutCard.offsetHeight}px`;
    }
  };

  updateSticky();
  new ResizeObserver(updateSticky).observe(document.body);
  window.addEventListener('resize', updateSticky, { passive: true });

  // ==========================================
  // 2. THE PARALLAX DRIFT ENGINE
  // ==========================================
  const heroCard = document.getElementById("hero-layer");
  const footer = document.querySelector("[data-footer]") || document.querySelector("footer"); 

  const HERO_SPEED = 0.35; 
  const PROJECTS_SPEED = 0.50; 
  const ABOUT_SPEED = 0.20;    

  const parallaxTick = () => {
    const vh = window.innerHeight;

    if (heroCard && projectsCard) {
      const projectsTop = projectsCard.getBoundingClientRect().top;
      if (projectsTop <= vh && projectsTop >= 0) {
        const overlap = vh - projectsTop;
        heroCard.style.transform = `translateY(${overlap * -HERO_SPEED}px)`;
      } else if (projectsTop > vh) {
        heroCard.style.transform = `translateY(0px)`;
      }
    }

    if (projectsCard && aboutCard) {
      const aboutTop = aboutCard.getBoundingClientRect().top;
      if (aboutTop <= vh && aboutTop >= 0) {
        const overlap = vh - aboutTop;
        projectsCard.style.transform = `translateY(${overlap * -PROJECTS_SPEED}px)`;
      } else if (aboutTop > vh) {
        projectsCard.style.transform = `translateY(0px)`;
      }
    }

    if (aboutCard && footer) {
      const footerTop = footer.getBoundingClientRect().top;
      if (footerTop <= vh && footerTop >= 0) {
        const overlap = vh - footerTop;
        aboutCard.style.transform = `translateY(${overlap * -ABOUT_SPEED}px)`;
      } else if (footerTop > vh) {
        aboutCard.style.transform = `translateY(0px)`;
      }
    }

    requestAnimationFrame(parallaxTick);
  };

  requestAnimationFrame(parallaxTick);
</script>