---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroParallax from "../components/HeroParallax.astro";

const hero = {
  heading: "I’m a designer who lives in the 'messy middle' of complex systems",
  subtext: "But outside of work, I’m usually found with a guitar in my hand, hunting for the best food in the city, or drawing weird things that have nothing to do with spreadsheets.",
  image: "/assets/about/profile.svg"
};

const timeline = [
  {
    title: "People First",
    media: "/assets/about/people.mp4",
    align: "right",
    scale: "1.25", 
    content: "My time on the frontlines of retail and high-stakes operations taught me that the people doing the work usually already have the best solutions. I don't invent complex fixes; I observe, listen, and design systems that support the humans on the ground."
  },
  {
    title: "Be Adaptable",
    media: "/assets/about/adaptable.mp4",
    align: "left",
    scale: "1.25", 
    content: "Breaking a global launch at Deliveroo taught me that rigid frameworks often fall apart in the real world. I treat every project as a reset, readily abandoning the script to adapt in the moment and keep the team moving forward."
  },
  {
    title: "Be Curious",
    media: "/assets/about/curious.mp4",
    align: "right",
    scale: "1.3", 
    content: "I don't wait for a brief or take 'we can't do that' at face value. Whether I'm untangling global logistics pipelines or writing my own C# scripts to unblock developers, I hunt down the missing context and build the bridges myself."
  }
];
---

<BaseLayout
  title="About Me | Liam Oxley"
  description="I'm a designer who lives in the 'messy middle' of complex systems."
>
  <div class="bg-[#F3F0FA] min-h-screen w-full pt-56 pb-48 overflow-x-hidden relative z-0">
    
    <HeroParallax>
      
      {/* 1. FAR SCATTER (slot="far") */}
      <Fragment slot="far">
        <div class="max-w-[1200px] mx-auto w-full h-full relative px-6">
          {/* Safe: Above text, top left */}
          <img src="/assets/about/shape-1.svg" class="absolute -top-8 left-[5%] w-6 opacity-40 organic-drift-far" />
          {/* Safe: Above text, near middle */}
          <img src="/assets/about/shape-2.svg" class="absolute -top-4 left-[45%] w-8 opacity-40 organic-drift-far" style="animation-delay: -2s" />
          {/* Safe: Pushed strictly BELOW the text box now (-bottom-16 guarantees no overlap) */}
          <img src="/assets/about/shape-3.svg" class="absolute -bottom-16 left-[20%] w-8 opacity-40 organic-drift-far" style="animation-delay: -5s" />
          {/* Safe: Moved away from image, floating in the center gap */}
          <img src="/assets/about/shape-4.svg" class="absolute top-[15%] right-[45%] w-6 opacity-40 organic-drift-far" style="animation-delay: -10s" />
        </div>
      </Fragment>

      {/* 2. MID SCATTER (slot="mid") */}
      <Fragment slot="mid">
        <div class="max-w-[1200px] mx-auto w-full h-full relative px-6">
          {/* Safe: Pushed completely outside the left boundary to balance the page weight */}
          <img src="/assets/about/shape-5.svg" class="absolute top-[35%] -left-8 w-14 opacity-60 organic-drift-mid" />
          {/* Safe: Strictly below the text in the bottom gap */}
          <img src="/assets/about/shape-6.svg" class="absolute -bottom-20 left-[45%] w-16 opacity-60 organic-drift-mid" style="animation-delay: -3s" />
          {/* Anchoring the bottom-left of the image */}
          <img src="/assets/about/shape-7.svg" class="absolute bottom-[5%] right-[28%] w-20 opacity-60 organic-drift-mid" style="animation-delay: -7s" />
        </div>
      </Fragment>

      {/* 3. CLOSE SCATTER (slot="front") */}
      <Fragment slot="front">
        <div class="max-w-[1200px] mx-auto w-full h-full relative px-6">
          {/* Pulled slightly up and away to let the image breathe */}
          <img src="/assets/about/shape-8.svg" class="absolute top-[5%] right-[22%] w-20 opacity-100 organic-drift-front" />
          {/* Anchoring the bottom-right edge */}
          <img src="/assets/about/shape-9.svg" class="absolute -bottom-6 -right-4 w-28 opacity-100 organic-drift-front" style="animation-delay: -6s" />
        </div>
      </Fragment>

      {/* 4. THE DEFAULT SLOT (Your Content) */}
      {/* Removed the rogue mt-16 to fix your spacing issue! */}
      <div class="max-w-[1200px] mx-auto px-6 mb-32 flex flex-col md:flex-row items-center justify-between gap-12 relative z-10">
        
        <div class="flex-1 max-w-[650px] flex flex-col gap-6 text-neutral-800 relative">
          <h1 class="font-serif font-normal text-[clamp(2rem,4vw,3rem)] leading-tight">{hero.heading}</h1>
          <p class="text-lg text-neutral-600 leading-relaxed">{hero.subtext}</p>
        </div>

       {/* We changed max-w-[320px] to max-w-[380px] right here 👇 */}
        <div class="flex-shrink-0 w-full max-w-[380px] flex justify-end relative">
          <img src={hero.image} alt="Liam Oxley" class="w-full h-auto object-contain" />
        </div>

      </div>
      
    </HeroParallax>

    {/* BRIDGE HEADER: Using your global CSS class */}
    <div class="w-full mx-auto max-w-[1200px] px-6 mb-16 relative z-10">
      <h3 class="bridge-header">My Design Principles</h3>
    </div>

    {/* TIMELINE SECTION */}
    <div class="w-full mx-auto max-w-[1200px] flex flex-col gap-24 px-6">
      {timeline.map((item) => (
        <div class="relative flex flex-col md:flex-row gap-8 md:gap-20 items-center w-full">
          
          {/* TEXT BLOCK */}
          <div class={`w-full md:w-1/2 flex flex-col gap-4 relative z-10 ${item.align === 'right' ? 'md:order-1' : 'md:order-2'}`}>
            <h3 class="font-serif text-[clamp(1.6rem,3vw,2.2rem)] font-normal text-neutral-800">{item.title}</h3>
            <p class="text-lg leading-relaxed text-neutral-600">{item.content}</p>
          </div>

          {/* VIDEO BLOCK */}
          <div class={`w-full md:w-1/2 flex ${item.align === 'right' ? 'md:order-2 justify-end' : 'md:order-1 justify-start'}`}>
            <video
              src={item.media}
              autoplay
              loop
              muted
              playsinline
              class="w-full max-w-[550px] h-auto mix-blend-multiply"
              style={`transform: scale(${item.scale || 1}); transform-origin: ${item.align === 'right' ? 'left center' : 'right center'};`}
            ></video>
          </div>

        </div>
      ))}
    </div>

  </div>
</BaseLayout>