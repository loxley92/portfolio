---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlockRenderer from "../../components/case-study/BlockRenderer.astro";
// 1. Import your RelatedProjects component
import RelatedProjects from "../../components/case-study/RelatedProjects.astro"; 
import { parseCaseStudy, resolveCaseStudyPath } from "../../lib/parse-case-study";

const { frontmatter, blocks } = parseCaseStudy(resolveCaseStudyPath("stats.md"));
---

<BaseLayout title={`${frontmatter.title} — Liam Oxley`} description={frontmatter.description}>
  {blocks.map((block, i) => (
    <BlockRenderer block={block} frontmatter={frontmatter} index={i} allBlocks={blocks} />
  ))}
  
  {/* 2. Drop it at the very bottom, inside the BaseLayout, and tell it where we are! */}
  <RelatedProjects currentSlug="engagement" />
  
  
</BaseLayout>
