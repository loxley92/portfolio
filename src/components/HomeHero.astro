---
interface Props {
  title: string;
  description: string;
  heroImage: string;
}

const { title, description, heroImage } = Astro.props;
---

<section class="bg-[linear-gradient(to_bottom,#F9DABF,#FFC297)] pt-36 md:pt-48 pb-20 md:pb-28">
  <div class="max-w-[1200px] mx-auto px-6 flex flex-col md:flex-row items-center gap-10 md:gap-16">
    <div class="text-wrap w-full md:w-1/2">
      <h1 class="font-serif font-medium text-[clamp(2.2rem,5vw,3.8rem)] leading-[1.1] tracking-[-0.02em] text-[#3c3c3c] text-balance">
        {title}
      </h1>
      {description && (
        <p class="mt-4 text-[1.1rem] leading-relaxed text-[#5a4a3a]">{description}</p>
      )}
    </div>
    <div class="media-wrap w-full md:w-1/2">
      <div class="inline-block w-full">
        <video
          src={heroImage}
          autoplay
          loop
          muted
          playsinline
          aria-hidden="true"
          class="w-full h-auto object-contain rounded-xl"
        />
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes slideUpFade {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .text-wrap {
    animation: slideUpFade 0.7s ease forwards;
  }

  .media-wrap {
    animation: slideUpFade 0.7s ease 0.15s forwards;
    opacity: 0;
  }
</style>
