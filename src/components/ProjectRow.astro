---
import MarkdownContent from "./case-study/MarkdownContent.astro";

interface Props {
  theme: string;
  link: string;
  image: string;
  imagePos?: "left" | "right";
  content: string;
}

const { link, image, imagePos = "left", content } = Astro.props;
const rowDir = imagePos === "left" ? "md:flex-row" : "md:flex-row-reverse";

const h4Match = content.match(/^####\s+(.+)$/m);
const tags = h4Match
  ? h4Match[1].split("•").map((s) => s.trim()).filter(Boolean)
  : [];
const cleanContent = content.replace(/^####\s+.+\n?/m, "");
---

<a href={link} class="block group hover:scale-[1.015] transition-all duration-300 ease-out cursor-pointer pb-16">
  <div class="w-full max-w-[1200px] mx-auto px-6 py-16">
    
    <div class={`flex flex-col ${rowDir} items-start gap-12`}>
      
      <div class="w-full md:w-[55%]">
        {tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mb-4">
            {tags.map((tag) => (
              <span class="border border-purple-300 bg-purple-50/40 text-purple-700 text-xs font-sans tracking-wide rounded-full px-3 py-1 flex items-center justify-center leading-none">
                {tag}
              </span>
            ))}
          </div>
        )}
        
        <div class="prose prose-lg prose-headings:font-serif prose-h3:text-4xl prose-h3:mt-2 prose-li:font-semibold prose-li:text-neutral-600 group-hover:prose-li:text-neutral-900 prose-li:marker:text-neutral-400 prose-li:transition-colors prose-li:duration-300">
          <MarkdownContent content={cleanContent} reveal={false} />
        </div>
        
        <div class="flex items-center gap-2 mt-8 text-xl font-extrabold tracking-wide text-purple-600 group-hover:text-purple-800 transition-colors duration-200">
          View More 
          
          <svg class="w-16 h-8 overflow-visible transition-transform duration-300 ease-out group-hover:translate-x-2" viewBox="0 0 64 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M 43 3 L 59 12 L 43 21 Z" fill="currentColor" />
            <path d="M 3 12 Q 8 4 13 12 T 23 12 T 33 12 T 43 12" stroke="currentColor" stroke-width="4.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
          </svg>
        </div>
      </div>

      <div class="w-full md:w-[45%]">
        
        <div class="w-full rounded-2xl bg-white p-2.5 border border-neutral-200/60 shadow-[0_4px_16px_rgba(0,0,0,0.03)] group-hover:shadow-[0_12px_24px_rgba(0,0,0,0.05)] transition-all duration-500 overflow-hidden">
          <img
            src={image}
            alt=""
            class="w-full h-auto rounded-xl block transition-transform duration-700 ease-[cubic-bezier(0.25,1,0.5,1)] group-hover:scale-[1.03]" 
          />
        </div>

      </div>
      
    </div>
  </div>
</a>