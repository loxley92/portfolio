---
interface Props {
  far?: string;
  front?: string;
}

const { far, front } = Astro.props;
---

<div class="relative w-fit mx-auto parallax-container flex justify-center items-center overflow-visible 2xl:min-h-[120vh]">
  
  {/* FAR LAYER */}
  {far && (
    <div class="absolute inset-0 z-0 layer-far pointer-events-none flex justify-center items-center">
      <img src={far} aria-hidden="true" class="w-full h-full object-contain organic-drift-far" />
    </div>
  )}
  
  {/* STATIC CENTER: Your Portrait */}
  <div class="relative z-10 block pointer-events-none">
    <slot />
  </div>

  {/* FRONT LAYER */}
  {front && (
    <div class="absolute inset-0 z-30 layer-front pointer-events-none flex justify-center items-center">
      <img src={front} aria-hidden="true" class="w-full h-full object-contain organic-drift-front" />
    </div>
  )}
</div>

<style>
  @media (hover: hover) and (pointer: fine) {
    .layer-far,
    .layer-front {
      will-change: transform;
    }

    /* 🖱️ JAVASCRIPT MOUSE TRACKING */
    .layer-far {
      transform: translate3d(calc(var(--mouse-x, 0) * 35px), calc(var(--mouse-y, 0) * 35px), 0);
    }

    .layer-front {
      transform: translate3d(calc(var(--mouse-x, 0) * -70px), calc(var(--mouse-y, 0) * -70px), 0);
    }

    /* 🌬️ WIDE ORGANIC TUMBLE ANIMATIONS */
    .organic-drift-far {
      animation: driftFar 35s linear infinite;
      will-change: transform;
    }

    .organic-drift-front {
      animation: driftFront 28s linear infinite;
      will-change: transform;
    }

    @keyframes driftFar {
      0%   { transform: translate(0px, -40px) rotate(0deg); }
      25%  { transform: translate(40px, 0px) rotate(90deg); }
      50%  { transform: translate(0px, 40px) rotate(180deg); }
      75%  { transform: translate(-40px, 0px) rotate(270deg); }
      100% { transform: translate(0px, -40px) rotate(360deg); }
    }

    @keyframes driftFront {
      0%   { transform: translate(0px, 60px) rotate(0deg); }
      25%  { transform: translate(-60px, 0px) rotate(-90deg); }
      50%  { transform: translate(0px, -60px) rotate(-180deg); }
      75%  { transform: translate(60px, 0px) rotate(-270deg); }
      100% { transform: translate(0px, 60px) rotate(-360deg); }
    }
  }
</style>

<script>
  function initParallaxEngine() {
    if (!window.matchMedia("(hover: hover) and (pointer: fine)").matches) return;

    const containers = document.querySelectorAll<HTMLElement>(".parallax-container");

    containers.forEach(container => {
      const shapes = Array.from(container.querySelectorAll<HTMLImageElement>('img[class*="organic-drift"]')).map((el) => {
        let scrollSpeed = 0;
        // Adjusted multipliers for tighter control around target assets
        if (el.classList.contains('organic-drift-far')) scrollSpeed = 0.25;
        if (el.classList.contains('organic-drift-mid')) scrollSpeed = 0.12;
        if (el.classList.contains('organic-drift-front')) scrollSpeed = -0.18;

        return {
          el,
          repelX: 0, repelY: 0,
          parallaxX: (Math.random() * 1.5 + 0.5) * (Math.random() > 0.5 ? 1 : -1),
          parallaxY: (Math.random() * 1.5 + 0.5) * (Math.random() > 0.5 ? 1 : -1),
          scrollSpeed
        };
      });

      if (shapes.length === 0) return;

      let targetMx = 0; let targetMy = 0;
      let currentMx = 0; let currentMy = 0;
      let mouseX = -1000; let mouseY = -1000;

      const handleMouseMove = (e: MouseEvent) => {
        targetMx = (e.clientX / window.innerWidth) * 2 - 1;
        targetMy = (e.clientY / window.innerHeight) * 2 - 1;
        mouseX = e.clientX;
        mouseY = e.clientY;
      };
      window.addEventListener("mousemove", handleMouseMove);

      const lerp = (a: number, b: number, t: number) => a + (b - a) * t;

      const tick = () => {
        if (!container.isConnected) {
          window.removeEventListener("mousemove", handleMouseMove);
          return;
        }

        currentMx = lerp(currentMx, targetMx, 0.04);
        currentMy = lerp(currentMy, targetMy, 0.04);

        // Calculate scroll offset based on screen viewport position
        const rect = container.getBoundingClientRect();
        const viewportCenter = window.innerHeight / 2;
        const containerCenter = rect.top + rect.height / 2;
        const distanceFromCenter = containerCenter - viewportCenter;

        shapes.forEach(shape => {
          const pX = currentMx * 30 * shape.parallaxX;
          const pY = currentMy * 30 * shape.parallaxY;

          // Displacement is now relative to the live container center point
          const scrollOffset = distanceFromCenter * shape.scrollSpeed;

          const shapeRect = shape.el.getBoundingClientRect();
          const shapeCenterX = shapeRect.left + shapeRect.width / 2;
          const shapeCenterY = shapeRect.top + shapeRect.height / 2;

          const dx = shapeCenterX - mouseX;
          const dy = shapeCenterY - mouseY;
          const distance = Math.sqrt(dx * dx + dy * dy);

          let rX = 0; let rY = 0;
          const repelRadius = 250;

          if (distance < repelRadius) {
            const force = (repelRadius - distance) / repelRadius;
            rX = (dx / distance) * force * 70;
            rY = (dy / distance) * force * 70;
          }

          shape.repelX = lerp(shape.repelX, rX, 0.1);
          shape.repelY = lerp(shape.repelY, rY, 0.1);

          shape.el.style.translate = `${pX + shape.repelX}px ${pY + shape.repelY + scrollOffset}px`;
        });

        requestAnimationFrame(tick);
      };

      requestAnimationFrame(tick);
    });
  }

  initParallaxEngine();
  document.addEventListener("astro:page-load", initParallaxEngine);
</script>