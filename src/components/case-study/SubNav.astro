---
interface Props {
  links: string[];
  glassmorphism?: boolean;
  themeColor?: string;
}

const { links, glassmorphism = true } = Astro.props;

const slugify = (s: string) =>
  s.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "");
---

<nav
  class:list={[
    "sticky z-40 w-full transition-[top] duration-400 ease-out transform-gpu will-change-[top]",
    glassmorphism
      ? "bg-page/70 backdrop-blur-md border-b border-white/40"
      : "bg-page border-b border-neutral-200",
  ]}
  style="top: var(--header-offset, 0px);"
  data-sub-nav
>
  <ul class="container-wide !my-0 flex gap-2 sm:gap-6 overflow-x-auto py-5">
    {links.map((label) => {
      const slug = slugify(label);
      return (
        <li>
          <a
            href={`#${slug}`}
            data-sub-nav-link={slug}
            aria-current="false"
            class="
              inline-block px-4 pt-2 pb-1 text-sm font-sans font-bold whitespace-nowrap 
              transition-all duration-300 ease-out no-underline origin-center
              border-b-2 border-transparent
              text-neutral-500 
              hover:text-black hover:border-b-neutral-300 hover:scale-105
              aria-[current='true']:text-black aria-[current='true']:border-b-[#4B32A8] aria-[current='true']:scale-105
            "
          >
            {label}
          </a>
        </li>
      );
    })}
  </ul>
</nav>

<script>
  let isManualScrolling = false;
  const links = Array.from(document.querySelectorAll<HTMLAnchorElement>("[data-sub-nav-link]"));

  function setActive(slug: string | null) {
    for (const a of links) {
      a.setAttribute("aria-current", a.dataset.subNavLink === slug ? "true" : "false");
    }
  }

  // Resolve targets
  type Target = { el: HTMLElement; slug: string; order: number };
  const targets: Target[] = [];
  links.forEach((a, i) => {
    const slug = a.dataset.subNavLink;
    if (!slug) return;
    const el = document.getElementById(slug);
    if (el) targets.push({ el, slug, order: i });
  });

  if (targets.length > 0) {
    const visible = new Set<string>();
    let lastActive: string | null = null;

    const pickActive = () => {
      if (isManualScrolling || visible.size === 0) return; 
      let best: Target | null = null;
      let bestTop = Infinity;
      for (const t of targets) {
        if (!visible.has(t.slug)) continue;
        const top = t.el.getBoundingClientRect().top;
        if (top < bestTop) {
          bestTop = top;
          best = t;
        }
      }
      if (best && best.slug !== lastActive) {
        lastActive = best.slug;
        setActive(best.slug);
      }
    };

    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          const slug = (entry.target as HTMLElement).id;
          if (entry.isIntersecting) visible.add(slug);
          else visible.delete(slug);
        }
        pickActive();
      },
      { rootMargin: "-30% 0px -65% 0px", threshold: 0 }
    );

    targets.forEach((t) => io.observe(t.el));

    const initFallback = () => {
      if (isManualScrolling) return;
      const trigger = window.innerHeight * 0.3;
      let best: Target | null = null;
      for (const t of targets) {
        const top = t.el.getBoundingClientRect().top;
        if (top <= trigger) best = t;
      }
      if (best && best.slug !== lastActive) {
        lastActive = best.slug;
        setActive(best.slug);
      }
    };
    initFallback();
    window.addEventListener("scroll", initFallback, { passive: true, once: true });
  }

  links.forEach((a) => {
    a.addEventListener("click", (e) => {
      const slug = a.dataset.subNavLink;
      if (!slug) return;
      const el = document.getElementById(slug);
      if (!el) return;
      e.preventDefault();

      isManualScrolling = true; 
      setActive(slug); 

      // 1. Calculate precise offsets and distance early
      const subNav = document.querySelector<HTMLElement>("[data-sub-nav]");
      const subNavH = subNav ? subNav.offsetHeight : 0;
      const offset = -(subNavH + 12); 
      
      // Calculate how far we ACTUALLY have to travel
      const distance = Math.abs(el.getBoundingClientRect().top + offset);
      const dynamicDuration = Math.min(1.2 + (distance / 2000), 2.8);
      
      // 2. Set dynamic lock release
      // If the jump is tiny (< 50px), release the lock almost instantly.
      // Otherwise, set the failsafe just 200ms after the animation should naturally end.
      const timeoutMs = distance < 50 ? 100 : (dynamicDuration * 1000) + 200;

      (window as any).__isJumping = true;

      const releaseLock = () => {
        clearTimeout((window as any).__jumpFailsafe);
        if ((window as any).__isJumping) {
          (window as any).__isJumping = false;
          window.dispatchEvent(new Event("scroll")); // Instantly forces header to check its position
        }
      };

      clearTimeout((window as any).__jumpFailsafe);
      (window as any).__jumpFailsafe = setTimeout(releaseLock, timeoutMs);

      const lenis = (window as any).__lenis;
      
      if (lenis && typeof lenis.scrollTo === "function") {
        lenis.scrollTo(el, { 
          offset,
          duration: dynamicDuration,
          easing: (t) => 1 - Math.pow(1 - t, 4), 
          onComplete: () => {
            isManualScrolling = false;
            // Shrunk buffer from 400ms down to 50ms for lightning-fast responsiveness
            setTimeout(releaseLock, 50);
          }
        });
      } else {
        const top = el.getBoundingClientRect().top + window.scrollY + offset;
        window.scrollTo({ top, behavior: "smooth" });
        setTimeout(() => { 
          isManualScrolling = false; 
          setTimeout(releaseLock, 50);
        }, 1000);
      }
      history.replaceState(null, "", `#${slug}`);
    });
  });
</script>