---
import { parseCaseStudy, resolveCaseStudyPath } from "../../lib/parse-case-study";
import ProjectRow from "../ProjectRow.astro";
import Reveal from "../Reveal.astro";

interface Props {
  currentSlug: string;
}

const { currentSlug } = Astro.props;

// 1. Read home.md EXACTLY like your index.astro does
const { blocks } = parseCaseStudy(resolveCaseStudyPath("home.md"));
const allProjectRows = blocks.filter((b) => b.kind === "project-row");

// 2. Filter out the case study we are currently looking at
const otherProjects = allProjectRows.filter((block: any) => {
  const link = (block.attrs?.link as string) || "";
  // If the link is "/work/navigation" and currentSlug is "navigation", this removes it.
  return !link.includes(currentSlug);
});

// 3. Pick a random project from the remaining list
const randomIndex = Math.floor(Math.random() * otherProjects.length);
const nextProject = otherProjects[randomIndex] || otherProjects[0];
---

{nextProject && (
  <div class="w-full relative z-10 border-t border-neutral-200 mt-24 pt-12 pb-24">
    
    {/* Label */}
    <div class="max-w-[1200px] mx-auto px-6">
      <p class="text-xs font-sans font-bold tracking-[0.15em] uppercase text-neutral-400">
        Up Next
      </p>
    </div>

    {/* We just reuse your flawless ProjectRow component! */}
    <Reveal delay={0.1} as="div">
      <ProjectRow
        theme={nextProject.attrs.theme as string}
        link={nextProject.attrs.link as string}
        image={nextProject.attrs.image as string}
        imagePos="right"
        content={nextProject.content || ""}
      />
    </Reveal>
    
  </div>
)}