---
import Reveal from "../Reveal.astro";

// Static for now — content stub that the other case studies will fill in.
const items = [
  { slug: "stats", title: "Stats Rework", img: "/assets/stats/hero.webp", color: "#cfeaff" },
  { slug: "navigation", title: "Core Navigation", img: "/assets/navigation/hero.webp", color: "#b9e6ff" },
  { slug: "wander", title: "Wander", img: "/assets/wander/home-case-study-wander-hero.webp", color: "#ffe7c2" },
];
---

<div class="grid gap-6 sm:grid-cols-3">
  {items.map((item, i) => (
    <Reveal delay={i * 0.08} as="div">
      <a
        href={`/work/${item.slug}`}
        class="block group rounded-2xl overflow-hidden bg-white shadow-[0_4px_24px_-12px_rgba(0,0,0,0.15)] transition-transform hover:-translate-y-1"
      >
        <div class="aspect-[4/3] overflow-hidden" style={`background: ${item.color};`}>
          <img
            src={item.img}
            alt={item.title}
            loading="lazy"
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
          />
        </div>
        <div class="p-4">
          <h4 class="text-h3">{item.title}</h4>
        </div>
      </a>
    </Reveal>
  ))}
</div>
