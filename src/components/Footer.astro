---
import { site, type NavLink } from "../lib/site-config";

const year = new Date().getFullYear();

// Resolve each footer column into a concrete list of links so the template
// stays simple. `kind: "work"` is sourced from `site.work` so a new case study
// automatically appears here.
type ResolvedColumn = { heading: string; links: NavLink[] };

const columns: ResolvedColumn[] = site.footer.columns.map((col) => {
  if (col.kind === "work") {
    return {
      heading: col.heading,
      links: site.work.map((w) => ({ href: `/work/${w.slug}`, label: w.title })),
    };
  }
  if (col.kind === "primary-nav") {
    return { heading: col.heading, links: site.primaryNav };
  }
  return { heading: col.heading, links: [] };
});
---

<footer
  class="relative w-full z-30 text-sm text-neutral-600"
  data-footer
>
  {/* THE CUSTOM PEACH WAVE */}
  <div class="absolute bottom-full left-0 w-full overflow-hidden leading-none">
    <svg
      aria-hidden="true"
      class="relative block w-full h-[40px] md:h-[60px]"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 1440 100"
      preserveAspectRatio="none"
    >
      <path 
        d="M0,50 C280,110 400,110 720,50 C1000,-10 1200,0 1440,30 L1440,100 L0,100 Z" 
        fill="#F6EBE2" 
      ></path>
    </svg>
  </div>

  {/* THE GRADIENT WRAPPER */}
  <div class="w-full bg-gradient-to-b from-[#F6EBE2] to-[#E6D0BE] pt-12 pb-5">
    <div class="container-wide grid gap-10 sm:grid-cols-2 md:grid-cols-4">
      
      {/* Brand Info */}
      <div class="flex flex-col gap-2">
        <p class="text-h3 text-neutral-900 font-bold">{site.name}</p>
        {site.tagline && <p>{site.tagline}</p>}
        <a
          href={`mailto:${site.email}`}
          class="mt-2 hover:text-[#4B32A8] transition-colors hover:underline underline-offset-4 break-all"
        >
          {site.email}
        </a>
      </div>

      {/* Dynamic Columns (Work, Site) */}
      {columns.map((col) => (
        <nav aria-labelledby={`footer-col-${col.heading.toLowerCase()}`}>
          <h4
            id={`footer-col-${col.heading.toLowerCase()}`}
            class="font-sans font-bold uppercase tracking-wider text-xs text-neutral-900 mb-3"
          >
            {col.heading}
          </h4>
          <ul class="flex flex-col gap-2">
            {col.links.map((link) => (
              <li>
                <a href={link.href} class="hover:text-[#4B32A8] transition-colors hover:underline underline-offset-4">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      ))}

      {/* Dynamic Socials */}
      {site.social.length > 0 && (
        <nav aria-labelledby="footer-col-elsewhere">
          <h4
            id="footer-col-elsewhere"
            class="font-sans font-bold uppercase tracking-wider text-xs text-neutral-900 mb-3"
          >
            Elsewhere
          </h4>
          <ul class="flex flex-col gap-2">
            {site.social.map((link) => (
              <li>
                <a
                  href={link.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="hover:text-[#4B32A8] transition-colors hover:underline underline-offset-4"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      )}
    </div>

    {/* Bottom Section: Copyright */}
    <div
      class="container-wide mt-10 pt-6 border-t border-black/10 flex flex-col sm:flex-row justify-between gap-2"
    >
      <span>© {year} {site.name}</span>
      {site.footer.note && <span>{site.footer.note}</span>}
    </div>
  </div>
</footer>