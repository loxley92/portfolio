---
import { site } from "../lib/site-config";

const navLinks = site.primaryNav;
const pathname = Astro.url.pathname;
// Check if we are on the home page (handles both dev and static trailing slashes)
const isHome = pathname === "/" || pathname === "/index.html";
---

<header
  class={isHome 
    ? "absolute top-0 left-0 right-0 z-50 w-full px-4 sm:px-6 md:px-12 py-4 sm:py-8 flex items-center justify-between bg-transparent"
    : "fixed top-0 left-0 right-0 z-50 w-full px-4 sm:px-6 md:px-12 py-4 sm:py-8 flex items-center justify-between transition-all duration-700 ease-[cubic-bezier(0.16,1,0.3,1)] bg-transparent"}
  data-header={!isHome ? "" : undefined}
>
  <a href="/" class="transition-transform hover:scale-105 active:scale-95" aria-label={site.name}>
    <img src="/assets/global/logo.svg" alt={site.name} class="h-9 w-auto" />
  </a>

  <nav class="flex items-center">
    <div class="flex gap-2 p-1.5 rounded-full border-2 border-purple/30 bg-purple/5 backdrop-blur-md shadow-sm">
      {navLinks.map((link) => (
        <a 
          href={link.href} 
          class="px-4 sm:px-8 py-0.3 rounded-full text-sm sm:text-[1.1rem] font-sans font-bold tracking-tight text-purple transition-all duration-200 hover:bg-purple/10 active:scale-95"
        >
          {link.label}
        </a>
      ))}
    </div>
  </nav>
</header>

<script>
  let lastScroll = window.scrollY;
  let ticking = false;
  let isHidden = false;
  
  const header = document.querySelector<HTMLElement>("[data-header]"); 
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  const glassClasses = ["bg-page/70", "backdrop-blur-md", "border-b", "border-white/40"];
  const solidClasses = ["border-transparent", "bg-transparent"]; 

  function update() {
    // 💡 If on the home page, the data-header attribute is gone, so this cleanly exits!
    if (!header) return; 
    
    const currentScroll = window.scrollY;

    if (currentScroll > 50) {
      header.classList.remove(...solidClasses);
      header.classList.add(...glassClasses);
    } else {
      header.classList.remove(...glassClasses);
      header.classList.add(...solidClasses);
    }

    const delta = currentScroll - lastScroll;

    if ((window as any).__isJumping) {
      isHidden = true; 
    } else {
      if (currentScroll <= 50) {
        isHidden = false; 
      } 
      else if (Math.abs(delta) > 5) {
        if (delta > 0) {
          isHidden = true; 
        } else {
          isHidden = false;
        }
      }
    }

    if (isHidden) {
      header.classList.add("-translate-y-full");
      document.documentElement.style.setProperty("--header-offset", "0px");
    } else {
      header.classList.remove("-translate-y-full");
      document.documentElement.style.setProperty("--header-offset", `${header.offsetHeight}px`);
    }

    lastScroll = currentScroll;
  }

  function onScroll() {
    if (!ticking) {
      window.requestAnimationFrame(() => {
        if (!reduceMotion) update();
        ticking = false;
      });
      ticking = true;
    }
  }

  if (!reduceMotion) update();
  window.addEventListener("scroll", onScroll, { passive: true });
  window.addEventListener("resize", () => {
    if (!reduceMotion) update();
  });

  // Intercept Work nav link: smooth-scroll on homepage, normal nav on subpages
  document.querySelectorAll<HTMLAnchorElement>('a[href="/#projects-layer"]').forEach((el) => {
    el.addEventListener("click", (e) => {
      const isHome = window.location.pathname === "/" || window.location.pathname === "/index.html";
      if (isHome && (window as any).__lenis) {
        e.preventDefault();
        (window as any).__lenis.scrollTo("#projects-layer", { offset: -80 });
      }
    });
  });
</script>